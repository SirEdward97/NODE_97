<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>

<body>
    <header>
        <%- include('../partials/header'); %>
    </header>
    <main class="container mt-3">
        <div class="jumbotron py-3">
            <h1 class="display-5 mb-4">Listado de Clientes</h1>
            
            <% if (clientes && clientes.length > 0) { %>
                <table id="tablita" class="table table-striped table-bordered align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Nombre</th>
                            <th>Email</th>
                            <th>Teléfono</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% clientes.forEach(function(cliente) { %>
                            <tr>
                                <td><%= cliente.nombre %></td>
                                <td><%= cliente.email %></td>
                                <td><%= cliente.telefono || 'No registra' %></td>
                                <td class="text-center">
                                  
                                    <button type="button" class="btn btn-sm btn-info text-white" 
                                        data-bs-toggle="modal" data-bs-target="#myModal"
                                        onclick="mostrarModal('<%= cliente.nombre %>', '<%= cliente.email %>', '<%= cliente.telefono %>')">
                                        Ver
                                    </button>

                                    <button type="button" class="btn btn-sm btn-info text-white"
                                        data-bs-toggle="modal" data-bs-target="#myModal"
                                        onclick="editarCliente('<%= cliente.nombre %>', '<%= cliente.email %>', '<%= cliente.telefono %>')"
                                        
                                        >
                                        Editar
                                    </button>

                                    <button type="button" class="btn btn-sm btn-info text-white" 
                                        data-bs-toggle="modal" data-bs-target="#myModal"
                                        onclick="eliminarCliente('<%= cliente.nombre %>', '<%= cliente.email %>', '<%= cliente.telefono %>')">
                                        Eliminar
                                    </button>

                                    
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            <% } else { %>
                <p>No hay clientes registrados.</p>
            <% } %>
        </div>
    </main>

    <div class="modal fade" id="myModal" tabindex="-1" aria-labelledby="modalTitulo" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitulo">Detalles del Cliente</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p><strong>Nombre:</strong> <span id="modalNombre"></span></p>
                    <p><strong>Email:</strong> <span id="modalEmail"></span></p>
                    <p><strong>Teléfono:</strong> <span id="modalTelefono"></span></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>

    <footer>
        <%- include('../partials/footer'); %>
    </footer>

    <!-- Script para actualizar los datos en el Modal -->
    <script>
        function mostrarModal(nombre, email, telefono) {
            document.getElementById('modalNombre').textContent = nombre;
            document.getElementById('modalEmail').textContent = email;
            document.getElementById('modalTelefono').textContent = telefono || 'No registra';

        }
        function editarCliente (nombre, email, telefono)
        {
            document.getElementById('modalNombre').textContent = nombre;
            document.getElementById('modalEmail').textContent = email;
            document.getElementById('modalTelefono').textContent = telefono || 'No registra';   
        }
        function eliminarCliente (nombre, email, telefono)
        {
            document.getElementById('modalNombre').textContent = nombre;
            document.getElementById('modalEmail').textContent = email;
            document.getElementById('modalTelefono').textContent = telefono || 'No registra';   
        }

    </script>
</body>

</html>